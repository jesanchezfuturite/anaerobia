---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Anaerobia | Ingeniería Inteligente en Sistemas de Pintura y Acabado">
  <main>
    <!-- A. Hero Section Cinematográfico -->
    <section class="relative min-h-screen overflow-hidden flex items-center">
      <!-- Background Video Local -->
      <div class="absolute inset-0 w-full h-full z-0 overflow-hidden bg-[var(--color-brand-navy)]">
        <video 
           class="absolute inset-0 w-full h-full object-cover opacity-60 mix-blend-luminosity" 
           autoplay loop muted playsinline>
          <source src="/videos/home.mp4" type="video/mp4" />
        </video>
      </div>
      
      <!-- Overlay -->
      <div class="absolute inset-0 bg-[var(--color-brand-navy)]/80 mix-blend-multiply z-10"></div>
      
      <!-- Contenido -->
      <div class="relative z-20 container mx-auto px-6 md:px-12 w-full mt-16">
        <div class="max-w-4xl hero-content">
          <span class="inline-block text-[var(--color-brand-lime)] font-semibold tracking-widest text-sm md:text-base mb-4 uppercase">
            Líderes en integración industrial
          </span>
          <h1 class="text-white font-saira italic font-extrabold text-5xl md:text-7xl leading-tight mb-6">
            Ingeniería Inteligente en Sistemas de Pintura y Acabado.
          </h1>
          <p class="text-gray-300 text-lg md:text-xl font-light max-w-2xl mb-8">
            Diseñamos e integramos proyectos 'llave en mano' para manufactura de alto volumen.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="#contacto" class="bg-[var(--color-brand-lime)] text-[var(--color-brand-navy)] font-semibold px-8 py-4 rounded hover:brightness-110 transition-all duration-300 transform hover:-translate-y-1">
              Hablar con un Ingeniero
            </a>
            <button class="flex items-center gap-2 border border-white text-white font-medium px-8 py-4 rounded hover:bg-white/10 transition-all duration-300 backdrop-blur-sm group">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white group-hover:text-[var(--color-brand-lime)] transition-colors" fill="currentColor" viewBox="0 0 16 16">
                <path d="M11.596 8.697l-6.363 3.692c-.54.313-1.233-.066-1.233-.697V4.308c0-.63.692-1.01 1.233-.696l6.363 3.692a.802.802 0 0 1 0 1.393z"/>
              </svg>
              Ver Proyectos
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- B. Marquee de Autoridad (Swiper.js) -->
    <section class="bg-white py-4 border-y border-gray-200 overflow-hidden flex items-center">
      <div class="container mx-auto px-6 flex flex-col md:flex-row items-center gap-6">
        <span class="text-gray-500 font-medium whitespace-nowrap text-sm mt-1 uppercase tracking-wide">
          Tecnología respaldada por aliados globales:
        </span>
        <div class="swiper marquee-swiper w-full">
          <div class="swiper-wrapper items-center">
            <div class="swiper-slide !w-auto px-8"><img src="/img/logos/fanuc.png" alt="FANUC" class="h-6 opacity-60 grayscale hover:grayscale-0 transition-all object-contain" onerror="this.outerHTML='<span class=\'text-2xl font-bold text-gray-400\'>FANUC</span>'" /></div>
            <div class="swiper-slide !w-auto px-8"><img src="/img/logos/graco.png" alt="GRACO" class="h-6 opacity-60 grayscale hover:grayscale-0 transition-all object-contain" onerror="this.outerHTML='<span class=\'text-2xl font-bold text-gray-400\'>GRACO</span>'" /></div>
            <div class="swiper-slide !w-auto px-8"><img src="/img/logos/binks.png" alt="BINKS" class="h-6 opacity-60 grayscale hover:grayscale-0 transition-all object-contain" onerror="this.outerHTML='<span class=\'text-2xl font-bold text-gray-400\'>BINKS</span>'" /></div>
            <div class="swiper-slide !w-auto px-8"><img src="/img/logos/gfs.png" alt="GFS" class="h-6 opacity-60 grayscale hover:grayscale-0 transition-all object-contain" onerror="this.outerHTML='<span class=\'text-2xl font-bold text-gray-400\'>GFS</span>'" /></div>
            <div class="swiper-slide !w-auto px-8"><img src="/img/logos/nordson.png" alt="NORDSON" class="h-6 opacity-60 grayscale hover:grayscale-0 transition-all object-contain" onerror="this.outerHTML='<span class=\'text-2xl font-bold text-gray-400\'>NORDSON</span>'" /></div>
            
            <!-- Duplicate for loop -->
            <div class="swiper-slide !w-auto px-8"><img src="/img/logos/fanuc.png" alt="FANUC" class="h-6 opacity-60 grayscale hover:grayscale-0 transition-all object-contain" onerror="this.outerHTML='<span class=\'text-2xl font-bold text-gray-400\'>FANUC</span>'" /></div>
            <div class="swiper-slide !w-auto px-8"><img src="/img/logos/graco.png" alt="GRACO" class="h-6 opacity-60 grayscale hover:grayscale-0 transition-all object-contain" onerror="this.outerHTML='<span class=\'text-2xl font-bold text-gray-400\'>GRACO</span>'" /></div>
            <div class="swiper-slide !w-auto px-8"><img src="/img/logos/binks.png" alt="BINKS" class="h-6 opacity-60 grayscale hover:grayscale-0 transition-all object-contain" onerror="this.outerHTML='<span class=\'text-2xl font-bold text-gray-400\'>BINKS</span>'" /></div>
            <div class="swiper-slide !w-auto px-8"><img src="/img/logos/gfs.png" alt="GFS" class="h-6 opacity-60 grayscale hover:grayscale-0 transition-all object-contain" onerror="this.outerHTML='<span class=\'text-2xl font-bold text-gray-400\'>GFS</span>'" /></div>
            <div class="swiper-slide !w-auto px-8"><img src="/img/logos/nordson.png" alt="NORDSON" class="h-6 opacity-60 grayscale hover:grayscale-0 transition-all object-contain" onerror="this.outerHTML='<span class=\'text-2xl font-bold text-gray-400\'>NORDSON</span>'" /></div>
          </div>
        </div>
      </div>
    </section>

    <!-- C. Bento Grid Dinámico -->
    <section id="soluciones" class="bg-[var(--color-industrial-gray)] py-24 pb-32 bento-grid-container px-6 md:px-12">
      <div class="container mx-auto">
        <div class="mb-16">
          <h2 class="text-3xl md:text-5xl font-saira font-bold text-[var(--color-brand-navy)]">
            Soluciones Industriales <span class="text-[var(--color-brand-lime)]">Altamente Especializadas</span>
          </h2>
          <p class="mt-4 text-gray-600 max-w-2xl text-lg">Integramos tecnologías de punta para maximizar la calidad y el rendimiento en la línea de producción de tu planta.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 auto-rows-[320px]">
          <!-- 1. Pintura en Polvo -->
          <div class="bento-card group overflow-hidden relative rounded-xl shadow-[0_8px_30px_rgb(0,0,0,0.12)] bg-white cursor-pointer">
            <img src="https://loremflickr.com/800/600/industry,factory?lock=1" alt="Pintura en Polvo" class="object-cover h-full w-full transform transition-transform duration-700 group-hover:scale-110" />
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-brand-navy)]/95 via-[var(--color-brand-navy)]/40 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-8 w-full">
              <h3 class="text-2xl font-bold text-white font-saira translate-y-4 group-hover:translate-y-0 transition-transform duration-300">Pintura en Polvo</h3>
              <p class="text-gray-200 mt-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300 delay-100 text-sm">Cabinas y sistemas eficientes para recubrimientos impecables de piezas metálicas con alta durabilidad.</p>
            </div>
          </div>

          <!-- 2. Pintura Líquida -->
          <div class="bento-card group overflow-hidden relative rounded-xl shadow-[0_8px_30px_rgb(0,0,0,0.12)] bg-white cursor-pointer">
            <img src="https://loremflickr.com/800/600/industry,robot?lock=2" alt="Pintura Líquida" class="object-cover h-full w-full transform transition-transform duration-700 group-hover:scale-110" />
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-brand-navy)]/95 via-[var(--color-brand-navy)]/40 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-8 w-full">
              <h3 class="text-2xl font-bold text-white font-saira translate-y-4 group-hover:translate-y-0 transition-transform duration-300">Pintura Líquida</h3>
              <p class="text-gray-200 mt-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300 delay-100 text-sm">Acabados estéticos de clase A con sistemas automatizados robotizados para la industria automotriz.</p>
            </div>
          </div>

          <!-- 3. Pretratamiento -->
          <div class="bento-card group overflow-hidden relative rounded-xl shadow-[0_8px_30px_rgb(0,0,0,0.12)] bg-[var(--color-brand-navy)] cursor-pointer">
            <img src="https://loremflickr.com/600/800/industry,welding?lock=3" alt="Pretratamiento" class="object-cover h-full w-full transform transition-transform duration-700 group-hover:scale-110 opacity-70 mix-blend-overlay" />
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-brand-navy)]/95 via-[var(--color-brand-navy)]/50 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-8 w-full">
              <h3 class="text-2xl font-bold text-[var(--color-brand-lime)] font-saira translate-y-4 group-hover:translate-y-0 transition-transform duration-300">Pretratamiento</h3>
              <p class="text-gray-300 mt-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300 delay-100 text-sm">Equipos de lavado de etapas múltiples asegurando la adherencia ideal antes del recubrimiento.</p>
            </div>
          </div>

          <!-- 4. Hornos de Curado -->
          <div class="bento-card group overflow-hidden relative rounded-xl shadow-[0_8px_30px_rgb(0,0,0,0.12)] bg-white cursor-pointer">
            <img src="https://loremflickr.com/800/600/industry,oven,metal?lock=4" alt="Hornos de Curado" class="object-cover h-full w-full transform transition-transform duration-700 group-hover:scale-110" />
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-brand-navy)]/95 via-[var(--color-brand-navy)]/40 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-8 w-full">
              <h3 class="text-2xl font-bold text-white font-saira translate-y-4 group-hover:translate-y-0 transition-transform duration-300">Hornos de Curado y Secado</h3>
              <p class="text-gray-200 mt-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300 delay-100 text-sm">Hornos de convección e infrarrojos diseñados térmicamente para eficiencia energética superlativa.</p>
            </div>
          </div>

          <!-- 5. Conveyors -->
          <div class="bento-card group overflow-hidden relative rounded-xl shadow-[0_8px_30px_rgb(0,0,0,0.12)] bg-white cursor-pointer">
            <img src="https://loremflickr.com/800/600/industry,conveyor?lock=5" alt="Sistemas Conveyor" class="object-cover h-full w-full transform transition-transform duration-700 group-hover:scale-110 object-center" />
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-brand-navy)]/95 via-[var(--color-brand-navy)]/40 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-8 w-full">
              <h3 class="text-2xl font-bold text-white font-saira translate-y-4 group-hover:translate-y-0 transition-transform duration-300">Transportadores / Conveyors</h3>
              <p class="text-gray-200 mt-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300 delay-100 text-sm">Desde sistemas overhead hasta floor conveyors. Movimiento exacto y fluido para tus piezas.</p>
            </div>
          </div>

          <!-- 6. Partes y Filtros -->
          <div class="bento-card group overflow-hidden relative rounded-xl shadow-[0_8px_30px_rgb(0,0,0,0.12)] bg-white cursor-pointer -translate-y-4 md:translate-y-0">
            <img src="https://loremflickr.com/800/600/industrial,engine,part?lock=45" alt="Partes y Filtros" class="object-cover h-full w-full transform transition-transform duration-700 group-hover:scale-110 object-center" />
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-brand-navy)]/95 via-[var(--color-brand-navy)]/40 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-8 w-full">
              <h3 class="text-2xl font-bold text-white font-saira translate-y-4 group-hover:translate-y-0 transition-transform duration-300">Partes y Filtros</h3>
              <p class="text-gray-200 mt-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300 delay-100 text-sm">Suministro de componentes críticos, refacciones y consumibles de alto rendimiento para tus equipos.</p>
            </div>
          </div>
        </div>
      </div>
    </section>



    <!-- NUEVA: E. Sección de Mantenimiento Preventivo -->
    <section id="mantenimiento" class="bg-[var(--color-brand-navy)] text-white py-24 px-6 md:px-12 relative">
      <div class="absolute top-0 right-0 w-64 h-64 bg-[var(--color-brand-blue)] rounded-full blur-3xl opacity-20 transform translate-x-1/2 -translate-y-1/2"></div>
      <div class="container mx-auto relative z-10">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-3xl md:text-5xl font-saira font-bold mb-4">Mantenimiento <span class="text-[var(--color-brand-lime)]">Preventivo</span></h2>
          <p class="text-gray-300 text-lg">Garantizamos el funcionamiento ininterrumpido de tu inversión técnica mediante inspecciones detalladas e intervenciones programadas.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 main-services-grid">
          <div class="bg-white/5 border border-white/10 p-8 rounded-xl hover:bg-white/10 transition-colors backdrop-blur-sm">
            <div class="w-14 h-14 bg-[var(--color-brand-blue)] flex items-center justify-center rounded-lg mb-6">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            </div>
            <h3 class="text-xl font-bold font-saira mb-3">Inspección Técnica</h3>
            <p class="text-gray-400 text-sm">Auditorías a cabinas, hornos, conveyors y sistemas de pretratamiento para prever desgaste de piezas.</p>
          </div>
          <div class="bg-[var(--color-brand-lime)] p-8 rounded-xl shadow-xl transform md:-translate-y-4">
            <div class="w-14 h-14 bg-[var(--color-brand-navy)] flex items-center justify-center rounded-lg mb-6">
              <svg class="w-7 h-7 text-[var(--color-brand-lime)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            </div>
            <h3 class="text-xl font-bold font-saira mb-3 text-[var(--color-brand-navy)]">Pólizas de Mantenimiento</h3>
            <p class="text-[var(--color-brand-navy)]/80 text-sm">Contratos programados mensuales o anuales para prolongar la vida útil y evitar paros de línea inesperados.</p>
          </div>
          <div class="bg-white/5 border border-white/10 p-8 rounded-xl hover:bg-white/10 transition-colors backdrop-blur-sm">
            <div class="w-14 h-14 bg-[var(--color-brand-blue)] flex items-center justify-center rounded-lg mb-6">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
            </div>
            <h3 class="text-xl font-bold font-saira mb-3">Refacciones Originales</h3>
            <p class="text-gray-400 text-sm">Asesoría e integración rápida de partes críticas de marcas como GRACO, FANUC, NORDSON y asociadas.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- F. Sección de Contacto Parallax -->
    <section id="contacto" class="relative py-24 md:py-32 flex items-center justify-center overflow-hidden parallax-footer">
      <img src="https://loremflickr.com/1600/900/industry,worker?lock=100" alt="Ingenieros interactuando con maquinaria" class="absolute inset-0 w-full h-full object-cover z-0 parallax-bg" />
      <div class="absolute inset-0 bg-[var(--color-brand-navy)]/90 z-10 mix-blend-multiply"></div>
      
      <div class="relative z-20 container mx-auto px-6">
        <div class="max-w-6xl mx-auto bg-white/10 backdrop-blur-xl border border-white/20 p-8 md:p-12 rounded-2xl shadow-2xl overflow-hidden flex flex-col lg:flex-row gap-12 items-center">
            
            <!-- Izquierda: Texto de Autoridad -->
            <div class="w-full lg:w-5/12 flex flex-col justify-center">
                <span class="inline-block text-[var(--color-brand-lime)] font-semibold tracking-widest text-sm mb-4 uppercase">Contacto Inicial</span>
                <h2 class="text-3xl md:text-5xl font-saira font-bold text-white mb-6 uppercase tracking-wider leading-tight">¿Listo para mejorar tu capacidad productiva?</h2>
                <p class="text-gray-300 text-lg mb-8 font-light">Nuestro equipo de ingeniería está listo para diseñar la solución exacta que tu línea de producción requiere.</p>
                
                <div class="space-y-6 hidden lg:block">
                  <div class="flex items-center gap-4 text-white group cursor-pointer hover:bg-white/5 p-3 -ml-3 rounded-xl transition-colors">
                    <div class="w-12 h-12 rounded-full bg-[var(--color-brand-lime)]/20 flex items-center justify-center group-hover:bg-[var(--color-brand-lime)] group-hover:-translate-y-1 transition-all">
                      <svg class="w-5 h-5 text-[var(--color-brand-lime)] group-hover:text-[var(--color-brand-navy)] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                    </div>
                    <div>
                      <span class="block text-xs uppercase text-gray-400 tracking-wider">Centro de Atención</span>
                      <span class="font-semibold">+52 (81) 1234 5678</span>
                    </div>
                  </div>
                  <div class="flex items-center gap-4 text-white group cursor-pointer hover:bg-white/5 p-3 -ml-3 rounded-xl transition-colors">
                    <div class="w-12 h-12 rounded-full bg-[var(--color-brand-lime)]/20 flex items-center justify-center group-hover:bg-[var(--color-brand-lime)] group-hover:-translate-y-1 transition-all">
                      <svg class="w-5 h-5 text-[var(--color-brand-lime)] group-hover:text-[var(--color-brand-navy)] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    </div>
                    <div>
                      <span class="block text-xs uppercase text-gray-400 tracking-wider">Correo Corporativo</span>
                      <span class="font-semibold">contacto@anaerobia.com</span>
                    </div>
                  </div>
                </div>
            </div>
            
            <!-- Derecha: Formulario Premium -->
            <div class="w-full lg:w-7/12 bg-white rounded-xl p-8 md:p-10 shadow-[0_20px_50px_rgba(8,_112,_184,_0.3)]">
               <form class="space-y-6">
                 <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                   <div class="group">
                     <label class="block text-xs font-bold text-gray-500 mb-2 uppercase tracking-widest group-focus-within:text-[var(--color-brand-navy)] transition-colors">Nombre Completo</label>
                     <input type="text" class="w-full px-4 py-3 border-b-2 border-gray-200 bg-gray-50/50 rounded-t-md focus:outline-none focus:border-[var(--color-brand-lime)] focus:bg-white transition-all" placeholder="Ej. Juan Pérez">
                   </div>
                   <div class="group">
                     <label class="block text-xs font-bold text-gray-500 mb-2 uppercase tracking-widest group-focus-within:text-[var(--color-brand-navy)] transition-colors">Empresa</label>
                     <input type="text" class="w-full px-4 py-3 border-b-2 border-gray-200 bg-gray-50/50 rounded-t-md focus:outline-none focus:border-[var(--color-brand-lime)] focus:bg-white transition-all" placeholder="Razón Social">
                   </div>
                 </div>
                 <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                   <div class="group">
                     <label class="block text-xs font-bold text-gray-500 mb-2 uppercase tracking-widest group-focus-within:text-[var(--color-brand-navy)] transition-colors">Correo Corporativo</label>
                     <input type="email" class="w-full px-4 py-3 border-b-2 border-gray-200 bg-gray-50/50 rounded-t-md focus:outline-none focus:border-[var(--color-brand-lime)] focus:bg-white transition-all" placeholder="hola@empresa.com">
                   </div>
                   <div class="group">
                     <label class="block text-xs font-bold text-gray-500 mb-2 uppercase tracking-widest group-focus-within:text-[var(--color-brand-navy)] transition-colors">Teléfono</label>
                     <input type="tel" class="w-full px-4 py-3 border-b-2 border-gray-200 bg-gray-50/50 rounded-t-md focus:outline-none focus:border-[var(--color-brand-lime)] focus:bg-white transition-all" placeholder="+52 81 0000 0000">
                   </div>
                 </div>
                 <div class="group">
                   <label class="block text-xs font-bold text-gray-500 mb-2 uppercase tracking-widest group-focus-within:text-[var(--color-brand-navy)] transition-colors">Requerimiento Técnico</label>
                   <textarea rows="3" class="w-full px-4 py-3 border-b-2 border-gray-200 bg-gray-50/50 rounded-t-md focus:outline-none focus:border-[var(--color-brand-lime)] focus:bg-white transition-all resize-none" placeholder="Describe brevemente tus necesidades de producción, integración o servicios..."></textarea>
                 </div>
                 <div class="pt-2">

---
---

<header class="fixed w-full z-50 transition-all duration-300" id="main-nav">
  <div class="absolute inset-0 bg-white" id="nav-bg"></div>
  <div class="container mx-auto px-6 relative z-10">
    <div class="flex items-center justify-between h-24 md:h-28">
      <!-- Logo Oficial -->
      <a href="/" class="flex items-center">
        <img src="https://anaerobia.com/wp-content/uploads/2023/02/AnaerobiaLogo-Horizontal-1.png" alt="Anaerobia Logo" class="w-56 md:w-72 lg:w-80 h-auto object-contain" />
      </a>

      <!-- Desktop Menu -->
      <nav class="hidden md:flex items-center gap-5 lg:gap-8">
        <a href="#nosotros" class="text-[var(--color-brand-navy)] hover:text-[var(--color-brand-lime)] font-semibold text-sm uppercase tracking-widest transition-colors">Nosotros</a>
        <a href="#productos" class="text-[var(--color-brand-navy)] hover:text-[var(--color-brand-lime)] font-semibold text-sm uppercase tracking-widest transition-colors">Productos</a>
        <a href="#galeria" class="text-[var(--color-brand-navy)] hover:text-[var(--color-brand-lime)] font-semibold text-sm uppercase tracking-widest transition-colors">Galería</a>
        <a href="#blog" class="text-[var(--color-brand-navy)] hover:text-[var(--color-brand-lime)] font-semibold text-sm uppercase tracking-widest transition-colors">Blog</a>
        <a href="#contacto" class="text-[var(--color-brand-navy)] hover:text-[var(--color-brand-lime)] font-semibold text-sm uppercase tracking-widest transition-colors">Contacto</a>
        <a href="#partes" class="text-[var(--color-brand-navy)] hover:text-[var(--color-brand-lime)] font-semibold text-sm uppercase tracking-widest transition-colors">Partes y Filtros</a>
      </nav>

      <!-- Mobile Button -->
      <button class="md:hidden text-[var(--color-brand-navy)]">
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const nav = document.getElementById("main-nav");
    const navBg = document.getElementById("nav-bg");
    
    // Add shadow when scrolling for depth
    if (window.scrollY < 50) {
      navBg.classList.remove('shadow-md');
    }
    
    window.addEventListener("scroll", () => {
      if (window.scrollY > 50) {
        navBg.classList.add('shadow-md');
      } else {
        navBg.classList.remove('shadow-md');
      }
    });
  });
</script>
